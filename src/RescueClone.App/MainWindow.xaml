<Window x:Class="RescueClone.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RescueClone" Height="620" Width="980" MinHeight="520" MinWidth="820">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,14">
            <TextBlock Text="RescueClone" FontSize="26" FontWeight="SemiBold" DockPanel.Dock="Left"/>
            <TextBlock Text="Directory image create, verify, and restore" Foreground="#555" VerticalAlignment="Bottom" Margin="12,0,0,3"/>
        </DockPanel>

        <TabControl Grid.Row="1">
            <TabItem Header="Create Image">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBox x:Name="SourcePathBox" Grid.Row="0" Margin="0,0,0,8" ToolTip="Source directory"/>
                    <TextBox x:Name="ImagePathBox" Grid.Row="1" Margin="0,0,0,8" ToolTip="Image output path"/>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
                        <ComboBox x:Name="CompressionBox" Width="180" HorizontalAlignment="Left" SelectedIndex="1" Margin="0,0,8,0">
                            <ComboBoxItem Content="None"/>
                            <ComboBoxItem Content="Medium"/>
                            <ComboBoxItem Content="High"/>
                        </ComboBox>
                        <ComboBox x:Name="FormatBox" Width="90" HorizontalAlignment="Left" SelectedIndex="1">
                            <ComboBoxItem Content="V1"/>
                            <ComboBoxItem Content="V2"/>
                        </ComboBox>
                    </StackPanel>
                    <PasswordBox x:Name="CreatePasswordBox" Grid.Row="3" Width="260" HorizontalAlignment="Left" Margin="0,0,0,8" ToolTip="Optional password"/>
                    <Button Grid.Row="4" Width="140" Height="34" HorizontalAlignment="Left" VerticalAlignment="Top" Content="Create Image" Click="CreateImage_Click"/>
                </Grid>
            </TabItem>
            <TabItem Header="Verify Image">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBox x:Name="VerifyImagePathBox" Grid.Row="0" Margin="0,0,0,8" ToolTip="Image path"/>
                    <PasswordBox x:Name="VerifyPasswordBox" Grid.Row="1" Width="260" HorizontalAlignment="Left" Margin="0,0,0,8" ToolTip="Optional password"/>
                    <TextBox x:Name="VerifyRepositoryPathBox" Grid.Row="2" Margin="0,0,0,8" ToolTip="Image repository path"/>
                    <TextBox x:Name="VerifyRepositoryPatternBox" Grid.Row="3" Width="180" HorizontalAlignment="Left" Text="*.rcimg" Margin="0,0,0,8" ToolTip="Repository image pattern"/>
                    <WrapPanel Grid.Row="4">
                        <Button Width="140" Height="34" Content="Verify Image" Click="VerifyImage_Click" Margin="0,0,8,0"/>
                        <Button Width="150" Height="34" Content="Compare Source" Click="CompareImage_Click" Margin="0,0,8,0"/>
                        <Button Width="150" Height="34" Content="Audit Protection" Click="AuditImageProtection_Click" Margin="0,0,8,0"/>
                        <Button Width="150" Height="34" Content="Protect Images" Click="ProtectImages_Click"/>
                    </WrapPanel>
                </Grid>
            </TabItem>
            <TabItem Header="Restore Image">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBox x:Name="RestoreImagePathBox" Grid.Row="0" Margin="0,0,0,8" ToolTip="Image path"/>
                    <TextBox x:Name="TargetPathBox" Grid.Row="1" Margin="0,0,0,8" ToolTip="Restore target directory"/>
                    <PasswordBox x:Name="RestorePasswordBox" Grid.Row="2" Width="260" HorizontalAlignment="Left" Margin="0,0,0,8" ToolTip="Optional password"/>
                    <CheckBox x:Name="OverwriteBox" Grid.Row="3" Content="Overwrite existing files" Margin="0,0,0,8"/>
                    <TextBox x:Name="ExtractPathsBox" Grid.Row="4" Margin="0,0,0,8" ToolTip="Relative file or folder paths to extract; separate multiple paths with semicolons"/>
                    <WrapPanel Grid.Row="5">
                        <Button Width="140" Height="34" Content="Browse Image" Click="BrowseImage_Click" Margin="0,0,8,0"/>
                        <Button Width="120" Height="34" Content="List Images" Click="ListImages_Click" Margin="0,0,8,0"/>
                        <Button Width="130" Height="34" Content="Audit Images" Click="AuditImages_Click" Margin="0,0,8,0"/>
                        <Button Width="140" Height="34" Content="Extract Paths" Click="ExtractImage_Click" Margin="0,0,8,0"/>
                        <Button Width="140" Height="34" Content="Project Image" Click="ProjectImage_Click" Margin="0,0,8,0"/>
                        <Button Width="150" Height="34" Content="List Projections" Click="ListProjections_Click" Margin="0,0,8,0"/>
                        <Button Width="160" Height="34" Content="Remove Projection" Click="UnprojectImage_Click" Margin="0,0,8,0"/>
                        <Button Width="140" Height="34" Content="Restore Image" Click="RestoreImage_Click"/>
                        <CheckBox x:Name="VerifyListBox" Content="Verify list" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </WrapPanel>
                </Grid>
            </TabItem>
            <TabItem Header="Backup Job">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBox x:Name="JobPathBox" Grid.Row="0" Margin="0,0,0,8" ToolTip="Backup job JSON path"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBox x:Name="JobIdBox" Width="180" ToolTip="Job ID" Margin="0,0,8,0"/>
                        <TextBox x:Name="JobNameBox" Width="260" ToolTip="Job name" Margin="0,0,8,0"/>
                        <CheckBox x:Name="JobEnabledBox" Content="Enabled" IsChecked="True" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBox x:Name="JobSourcePathBox" Grid.Row="2" Margin="0,0,0,8" ToolTip="Source directory"/>
                    <TextBox x:Name="JobImagePathBox" Grid.Row="3" Margin="0,0,0,8" ToolTip="Image output path"/>
                    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,8">
                        <ComboBox x:Name="JobCompressionBox" Width="180" SelectedIndex="1" Margin="0,0,8,0">
                            <ComboBoxItem Content="None"/>
                            <ComboBoxItem Content="Medium"/>
                            <ComboBoxItem Content="High"/>
                        </ComboBox>
                        <CheckBox x:Name="JobVerifyAfterCreateBox" Content="Verify after create" IsChecked="True" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBox x:Name="JobLogDirectoryBox" Width="260" ToolTip="Optional log directory"/>
                    </StackPanel>
                    <TextBox x:Name="JobTransferPathBox" Grid.Row="5" Margin="0,0,0,8" ToolTip="Export output path or import target path"/>
                    <TextBox x:Name="JobDirectoryBox" Grid.Row="6" Margin="0,0,0,8" ToolTip="Backup job directory for listing"/>
                    <WrapPanel Grid.Row="7">
                        <CheckBox x:Name="ForceDisabledJobBox" Content="Force disabled job" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Button Width="140" Height="34" Content="Create Job" Click="CreateJob_Click" Margin="0,0,8,0"/>
                        <Button Width="140" Height="34" Content="Update Job" Click="UpdateJob_Click" Margin="0,0,8,0"/>
                        <Button Width="140" Height="34" Content="Delete Job" Click="DeleteJob_Click" Margin="0,0,8,0"/>
                        <Button Width="140" Height="34" Content="Export Job" Click="ExportJob_Click" Margin="0,0,8,0"/>
                        <Button Width="140" Height="34" Content="Import Job" Click="ImportJob_Click" Margin="0,0,8,0"/>
                        <Button Width="140" Height="34" Content="List Jobs" Click="ListJobs_Click" Margin="0,0,8,0"/>
                        <Button Width="140" Height="34" Content="Job Status" Click="JobStatus_Click" Margin="0,0,8,0"/>
                        <Button Width="140" Height="34" Content="Validate Job" Click="ValidateJob_Click" Margin="0,0,8,0"/>
                        <Button Width="140" Height="34" Content="Run Job" Click="RunJob_Click"/>
                    </WrapPanel>
                </Grid>
            </TabItem>
            <TabItem Header="Restore Plan">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBox x:Name="PlanImagePathBox" Grid.Row="0" Margin="0,0,0,8" ToolTip="Image path"/>
                    <TextBox x:Name="PlanTargetDiskIdBox" Grid.Row="1" Margin="0,0,0,8" ToolTip="Target disk identifier"/>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
                        <ComboBox x:Name="PlanBootModeBox" Width="120" SelectedIndex="1" Margin="0,0,8,0">
                            <ComboBoxItem Content="Unknown"/>
                            <ComboBoxItem Content="Bios"/>
                            <ComboBoxItem Content="Uefi"/>
                        </ComboBox>
                        <TextBox x:Name="PlanTargetDiskSizeBox" Width="180" ToolTip="Target disk size bytes" Margin="0,0,8,0"/>
                        <TextBox x:Name="PlanRequiredBytesBox" Width="180" ToolTip="Required bytes override"/>
                    </StackPanel>
                    <TextBox x:Name="PlanBcdStorePathBox" Grid.Row="3" Margin="0,0,0,8" ToolTip="BCD store path"/>
                    <PasswordBox x:Name="PlanPasswordBox" Grid.Row="4" Width="260" HorizontalAlignment="Left" Margin="0,0,0,8" ToolTip="Optional image password"/>
                    <StackPanel Grid.Row="5" Orientation="Horizontal">
                        <CheckBox x:Name="PlanCurrentSystemDiskBox" Content="Target is current system disk" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <CheckBox x:Name="PlanHasEfiBox" Content="Has EFI System Partition" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Button Width="140" Height="34" Content="Plan Restore" Click="PlanRestore_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="Rescue">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBox x:Name="RescueAnswerPathBox" Grid.Row="0" Margin="0,0,0,8" ToolTip="Rescue answer JSON path"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBox x:Name="RescueRepositoryBox" Width="360" ToolTip="Backup repository folder" Margin="0,0,8,0"/>
                        <TextBox x:Name="RescueImageBox" Width="360" ToolTip="Image path or repository-relative image name"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBox x:Name="RescueTargetDiskBox" Width="220" ToolTip="Target disk identifier" Margin="0,0,8,0"/>
                        <ComboBox x:Name="RescueBootModeBox" Width="120" SelectedIndex="0" Margin="0,0,8,0">
                            <ComboBoxItem Content="Unknown"/>
                            <ComboBoxItem Content="Bios"/>
                            <ComboBoxItem Content="Uefi"/>
                        </ComboBox>
                        <TextBox x:Name="RescueTargetDiskSizeBox" Width="170" ToolTip="Target disk size bytes" Margin="0,0,8,0"/>
                        <TextBox x:Name="RescueRequiredBytesBox" Width="170" ToolTip="Required bytes override"/>
                    </StackPanel>
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBox x:Name="RescueBcdStoreBox" Width="260" ToolTip="BCD store path" Margin="0,0,8,0"/>
                        <TextBox x:Name="RescueDriverDirectoriesBox" Width="300" ToolTip="Driver directories separated by semicolons" Margin="0,0,8,0"/>
                        <TextBox x:Name="RescueNetworkSharesBox" Width="300" ToolTip="Network shares separated by semicolons"/>
                    </StackPanel>
                    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,8">
                        <PasswordBox x:Name="RescuePasswordBox" Width="220" ToolTip="Optional image password" Margin="0,0,12,0"/>
                        <CheckBox x:Name="RescueCurrentSystemDiskBox" Content="Target is current system disk" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <CheckBox x:Name="RescueHasEfiBox" Content="Has EFI System Partition" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <CheckBox x:Name="RescueRepairBootBox" Content="Repair boot" IsChecked="True" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <CheckBox x:Name="RescueRebootBox" Content="Reboot after restore" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <CheckBox x:Name="RescueVerifyImageBox" Content="Verify image" VerticalAlignment="Center"/>
                    </StackPanel>
                    <WrapPanel Grid.Row="5">
                        <Button Width="170" Height="34" Content="Create Answer" Click="CreateRescueAnswer_Click" Margin="0,0,8,0"/>
                        <Button Width="170" Height="34" Content="Validate Answer" Click="ValidateRescueAnswer_Click"/>
                    </WrapPanel>
                </Grid>
            </TabItem>
            <TabItem Header="Operations">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBox x:Name="OperationRequestPathBox" Grid.Row="0" Margin="0,0,0,8" ToolTip="Operation request JSON path"/>
                    <TextBox x:Name="OperationLogDirectoryBox" Grid.Row="1" Margin="0,0,0,8" ToolTip="Optional operation log directory"/>
                    <TextBox x:Name="OperationPipeNameBox" Grid.Row="2" Margin="0,0,0,8" ToolTip="Service pipe name"/>
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBox x:Name="ServiceNameBox" Width="180" ToolTip="Windows Service name" Margin="0,0,8,0"/>
                        <TextBox x:Name="ServiceDisplayNameBox" Width="220" ToolTip="Windows Service display name" Margin="0,0,8,0"/>
                        <TextBox x:Name="ServiceCliPathBox" Width="320" ToolTip="rc.exe path for Windows Service"/>
                    </StackPanel>
                    <WrapPanel Grid.Row="4" Margin="0,0,0,8">
                        <Button Width="140" Height="34" Content="Run Operation" Click="RunOperation_Click" Margin="0,0,8,0"/>
                        <Button Width="180" Height="34" Content="Run Via Service" Click="RunServiceOperation_Click" Margin="0,0,8,0"/>
                        <Button Width="150" Height="34" Content="Plan Service" Click="PlanService_Click" Margin="0,0,8,0"/>
                        <Button Width="150" Height="34" Content="Install Service" Click="InstallService_Click" Margin="0,0,8,0"/>
                        <Button Width="150" Height="34" Content="Service Status" Click="ServiceStatus_Click" Margin="0,0,8,0"/>
                        <Button Width="140" Height="34" Content="Start Service" Click="StartService_Click" Margin="0,0,8,0"/>
                        <Button Width="140" Height="34" Content="Stop Service" Click="StopService_Click" Margin="0,0,8,0"/>
                        <Button Width="170" Height="34" Content="Set Recovery" Click="SetServiceRecovery_Click" Margin="0,0,8,0"/>
                        <Button Width="170" Height="34" Content="Recovery Status" Click="ServiceRecoveryStatus_Click" Margin="0,0,8,0"/>
                        <Button Width="160" Height="34" Content="Uninstall Service" Click="UninstallService_Click"/>
                    </WrapPanel>
                </Grid>
            </TabItem>
            <TabItem Header="Retention">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBox x:Name="RetentionRepositoryBox" Grid.Row="0" Margin="0,0,0,8" ToolTip="Repository folder"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBox x:Name="RetentionPatternBox" Width="160" Text="*.rcimg" ToolTip="File pattern" Margin="0,0,8,0"/>
                        <TextBox x:Name="RetentionKeepCountBox" Width="120" ToolTip="Keep count" Margin="0,0,8,0"/>
                        <TextBox x:Name="RetentionMaxAgeDaysBox" Width="120" ToolTip="Max age days" Margin="0,0,8,0"/>
                        <TextBox x:Name="RetentionMinFreeBytesBox" Width="180" ToolTip="Minimum free bytes" Margin="0,0,8,0"/>
                        <TextBox x:Name="RetentionDailyKeepBox" Width="90" ToolTip="GFS daily keep" Margin="0,0,8,0"/>
                        <TextBox x:Name="RetentionWeeklyKeepBox" Width="90" ToolTip="GFS weekly keep" Margin="0,0,8,0"/>
                        <TextBox x:Name="RetentionMonthlyKeepBox" Width="90" ToolTip="GFS monthly keep"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                        <Button Width="140" Height="34" Content="Plan Retention" Click="PlanRetention_Click" Margin="0,0,8,0"/>
                        <Button Width="140" Height="34" Content="Apply Retention" Click="ApplyRetention_Click" Margin="0,0,8,0"/>
                        <Button Width="150" Height="34" Content="Plan GFS" Click="PlanGfsRetention_Click" Margin="0,0,8,0"/>
                        <Button Width="150" Height="34" Content="Apply GFS" Click="ApplyGfsRetention_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="Scheduler">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBox x:Name="ScheduleTaskNameBox" Grid.Row="0" Margin="0,0,0,8" ToolTip="Task name"/>
                    <TextBox x:Name="ScheduleJobFileBox" Grid.Row="1" Margin="0,0,0,8" ToolTip="Backup job JSON path"/>
                    <TextBox x:Name="ScheduleCliPathBox" Grid.Row="2" Margin="0,0,0,8" ToolTip="rc.exe path"/>
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,8">
                        <ComboBox x:Name="ScheduleFrequencyBox" Width="120" SelectedIndex="0" Margin="0,0,8,0">
                            <ComboBoxItem Content="Daily"/>
                            <ComboBoxItem Content="Weekly"/>
                            <ComboBoxItem Content="Monthly"/>
                            <ComboBoxItem Content="Event"/>
                        </ComboBox>
                        <TextBox x:Name="ScheduleTimeBox" Width="90" Text="02:00" ToolTip="Start time HH:mm" Margin="0,0,8,0"/>
                        <TextBox x:Name="ScheduleEventLogBox" Width="120" ToolTip="Event log for event schedules" Margin="0,0,8,0"/>
                        <TextBox x:Name="ScheduleEventIdBox" Width="90" ToolTip="Event ID" Margin="0,0,8,0"/>
                        <TextBox x:Name="ScheduleEventSourceBox" Width="180" ToolTip="Optional event source" Margin="0,0,8,0"/>
                        <CheckBox x:Name="ScheduleRunMissedBox" Content="Run missed backup on next start" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    </StackPanel>
                    <StackPanel Grid.Row="4" Orientation="Horizontal">
                        <Button Width="130" Height="34" Content="Plan Schedule" Click="PlanSchedule_Click" Margin="0,0,8,0"/>
                        <Button Width="150" Height="34" Content="Register Schedule" Click="RegisterSchedule_Click" Margin="0,0,8,0"/>
                        <Button Width="150" Height="34" Content="Schedule Status" Click="ScheduleStatus_Click" Margin="0,0,8,0"/>
                        <Button Width="140" Height="34" Content="Run Schedule" Click="RunSchedule_Click" Margin="0,0,8,0"/>
                        <Button Width="160" Height="34" Content="Unregister Schedule" Click="UnregisterSchedule_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="Volumes">
                <Grid Margin="12">
                    <Button Width="140" Height="34" HorizontalAlignment="Left" VerticalAlignment="Top" Content="Refresh Volumes" Click="RefreshVolumes_Click"/>
                </Grid>
            </TabItem>
            <TabItem Header="Disks">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Width="140" Height="34" Content="Refresh Disks" Click="RefreshDisks_Click" Margin="0,0,8,0"/>
                        <TextBox x:Name="DiskSafetyNumberBox" Width="120" ToolTip="Target disk number" Margin="0,0,8,0"/>
                        <TextBox x:Name="DiskSafetyFingerprintBox" Width="360" ToolTip="Optional expected disk fingerprint" Margin="0,0,8,0"/>
                        <CheckBox x:Name="DiskSafetyAllowBootSystemBox" Content="Allow boot/system" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    </StackPanel>
                    <Button Grid.Row="1" Width="160" Height="34" HorizontalAlignment="Left" Content="Check Disk Safety" Click="CheckDiskSafety_Click"/>
                </Grid>
            </TabItem>
            <TabItem Header="Logs">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBox x:Name="LogDirectoryBox" Grid.Row="0" Margin="0,0,0,8" ToolTip="Backup job log directory"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal">
                        <TextBox x:Name="LogPatternBox" Width="160" Text="*.json" ToolTip="Log file pattern" Margin="0,0,8,0"/>
                        <Button Width="140" Height="34" Content="List Logs" Click="ListLogs_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="Native Engine">
                <Grid Margin="12">
                    <Button Width="160" Height="34" HorizontalAlignment="Left" VerticalAlignment="Top" Content="Native Status" Click="NativeStatus_Click"/>
                </Grid>
            </TabItem>
        </TabControl>

        <TextBox x:Name="OutputBox" Grid.Row="2" Height="120" Margin="0,14,0,0" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
    </Grid>
</Window>
