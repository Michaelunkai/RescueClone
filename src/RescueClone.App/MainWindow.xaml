<Window x:Class="RescueClone.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RescueClone" Height="620" Width="980" MinHeight="520" MinWidth="820">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,14">
            <TextBlock Text="RescueClone" FontSize="26" FontWeight="SemiBold" DockPanel.Dock="Left"/>
            <TextBlock Text="Directory image create, verify, and restore" Foreground="#555" VerticalAlignment="Bottom" Margin="12,0,0,3"/>
        </DockPanel>

        <TabControl Grid.Row="1">
            <TabItem Header="Create Image">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBox x:Name="SourcePathBox" Grid.Row="0" Margin="0,0,0,8" ToolTip="Source directory"/>
                    <TextBox x:Name="ImagePathBox" Grid.Row="1" Margin="0,0,0,8" ToolTip="Image output path"/>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
                        <ComboBox x:Name="CompressionBox" Width="180" HorizontalAlignment="Left" SelectedIndex="1" Margin="0,0,8,0">
                            <ComboBoxItem Content="None"/>
                            <ComboBoxItem Content="Medium"/>
                            <ComboBoxItem Content="High"/>
                        </ComboBox>
                        <ComboBox x:Name="FormatBox" Width="90" HorizontalAlignment="Left" SelectedIndex="1">
                            <ComboBoxItem Content="V1"/>
                            <ComboBoxItem Content="V2"/>
                        </ComboBox>
                    </StackPanel>
                    <PasswordBox x:Name="CreatePasswordBox" Grid.Row="3" Width="260" HorizontalAlignment="Left" Margin="0,0,0,8" ToolTip="Optional password"/>
                    <Button Grid.Row="4" Width="140" Height="34" HorizontalAlignment="Left" VerticalAlignment="Top" Content="Create Image" Click="CreateImage_Click"/>
                </Grid>
            </TabItem>
            <TabItem Header="Verify Image">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBox x:Name="VerifyImagePathBox" Grid.Row="0" Margin="0,0,0,8" ToolTip="Image path"/>
                    <PasswordBox x:Name="VerifyPasswordBox" Grid.Row="1" Width="260" HorizontalAlignment="Left" Margin="0,0,0,8" ToolTip="Optional password"/>
                    <Button Grid.Row="2" Width="140" Height="34" HorizontalAlignment="Left" VerticalAlignment="Top" Content="Verify Image" Click="VerifyImage_Click"/>
                </Grid>
            </TabItem>
            <TabItem Header="Restore Image">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBox x:Name="RestoreImagePathBox" Grid.Row="0" Margin="0,0,0,8" ToolTip="Image path"/>
                    <TextBox x:Name="TargetPathBox" Grid.Row="1" Margin="0,0,0,8" ToolTip="Restore target directory"/>
                    <PasswordBox x:Name="RestorePasswordBox" Grid.Row="2" Width="260" HorizontalAlignment="Left" Margin="0,0,0,8" ToolTip="Optional password"/>
                    <CheckBox x:Name="OverwriteBox" Grid.Row="3" Content="Overwrite existing files" Margin="0,0,0,8"/>
                    <Button Grid.Row="4" Width="140" Height="34" HorizontalAlignment="Left" VerticalAlignment="Top" Content="Restore Image" Click="RestoreImage_Click"/>
                </Grid>
            </TabItem>
            <TabItem Header="Backup Job">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBox x:Name="JobPathBox" Grid.Row="0" Margin="0,0,0,8" ToolTip="Backup job JSON path"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal">
                        <CheckBox x:Name="ForceDisabledJobBox" Content="Force disabled job" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Button Width="140" Height="34" Content="Validate Job" Click="ValidateJob_Click" Margin="0,0,8,0"/>
                        <Button Width="140" Height="34" Content="Run Job" Click="RunJob_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="Restore Plan">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBox x:Name="PlanImagePathBox" Grid.Row="0" Margin="0,0,0,8" ToolTip="Image path"/>
                    <TextBox x:Name="PlanTargetDiskIdBox" Grid.Row="1" Margin="0,0,0,8" ToolTip="Target disk identifier"/>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
                        <ComboBox x:Name="PlanBootModeBox" Width="120" SelectedIndex="1" Margin="0,0,8,0">
                            <ComboBoxItem Content="Unknown"/>
                            <ComboBoxItem Content="Bios"/>
                            <ComboBoxItem Content="Uefi"/>
                        </ComboBox>
                        <TextBox x:Name="PlanTargetDiskSizeBox" Width="180" ToolTip="Target disk size bytes" Margin="0,0,8,0"/>
                        <TextBox x:Name="PlanRequiredBytesBox" Width="180" ToolTip="Required bytes override"/>
                    </StackPanel>
                    <TextBox x:Name="PlanBcdStorePathBox" Grid.Row="3" Margin="0,0,0,8" ToolTip="BCD store path"/>
                    <PasswordBox x:Name="PlanPasswordBox" Grid.Row="4" Width="260" HorizontalAlignment="Left" Margin="0,0,0,8" ToolTip="Optional image password"/>
                    <StackPanel Grid.Row="5" Orientation="Horizontal">
                        <CheckBox x:Name="PlanCurrentSystemDiskBox" Content="Target is current system disk" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <CheckBox x:Name="PlanHasEfiBox" Content="Has EFI System Partition" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Button Width="140" Height="34" Content="Plan Restore" Click="PlanRestore_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="Operations">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBox x:Name="OperationRequestPathBox" Grid.Row="0" Margin="0,0,0,8" ToolTip="Operation request JSON path"/>
                    <TextBox x:Name="OperationLogDirectoryBox" Grid.Row="1" Margin="0,0,0,8" ToolTip="Optional operation log directory"/>
                    <Button Grid.Row="2" Width="140" Height="34" HorizontalAlignment="Left" VerticalAlignment="Top" Content="Run Operation" Click="RunOperation_Click"/>
                </Grid>
            </TabItem>
            <TabItem Header="Volumes">
                <Grid Margin="12">
                    <Button Width="140" Height="34" HorizontalAlignment="Left" VerticalAlignment="Top" Content="Refresh Volumes" Click="RefreshVolumes_Click"/>
                </Grid>
            </TabItem>
            <TabItem Header="Native Engine">
                <Grid Margin="12">
                    <Button Width="160" Height="34" HorizontalAlignment="Left" VerticalAlignment="Top" Content="Native Status" Click="NativeStatus_Click"/>
                </Grid>
            </TabItem>
        </TabControl>

        <TextBox x:Name="OutputBox" Grid.Row="2" Height="120" Margin="0,14,0,0" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
    </Grid>
</Window>
